---
// ContactForm.astro - A reusable contact form component
// Uses Formspree for form handling (replace YOUR_FORM_ID with actual ID)

interface Props {
  formId?: string;
  redirectUrl?: string;
  showPackageSelect?: boolean;
}

const { 
  formId = "YOUR_FORM_ID", // Replace with actual Formspree form ID
  redirectUrl = "/tak",
  showPackageSelect = true 
} = Astro.props;
---

<form 
  action={`https://formspree.io/f/${formId}`}
  method="POST"
  class="space-y-6"
  id="contact-form"
>
  <!-- Hidden fields for Formspree configuration -->
  <input type="hidden" name="_subject" value="Ny henvendelse fra Website Rescue" />
  <input type="hidden" name="_replyto" value="nikolaj_fl@hotmail.com" />
  <input type="hidden" name="_redirect" value={redirectUrl} />
  
  <!-- Name field -->
  <div class="form-group">
    <label for="name" class="block text-sm font-semibold mb-2">
      Dit navn <span class="text-red-500">*</span>
    </label>
    <input
      type="text"
      id="name"
      name="name"
      required
      placeholder="F.eks. Lars Jensen"
      class="w-full px-4 py-3 bg-background border border-border rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent transition-all"
    />
  </div>
  
  <!-- Email field -->
  <div class="form-group">
    <label for="email" class="block text-sm font-semibold mb-2">
      Din email <span class="text-red-500">*</span>
    </label>
    <input
      type="email"
      id="email"
      name="email"
      required
      placeholder="lars@virksomhed.dk"
      class="w-full px-4 py-3 bg-background border border-border rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent transition-all"
    />
  </div>
  
  <!-- Website field -->
  <div class="form-group">
    <label for="website" class="block text-sm font-semibold mb-2">
      Din hjemmeside <span class="text-red-500">*</span>
    </label>
    <input
      type="url"
      id="website"
      name="website"
      required
      placeholder="https://..."
      class="w-full px-4 py-3 bg-background border border-border rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent transition-all"
    />
  </div>
  
  <!-- Package selection (optional) -->
  {showPackageSelect && (
    <div class="form-group">
      <label for="package" class="block text-sm font-semibold mb-2">
        Interesseret pakke
      </label>
      <select
        id="package"
        name="package"
        class="w-full px-4 py-3 bg-background border border-border rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent transition-all"
      >
        <option value="">Vælg pakke (valgfri)</option>
        <option value="starter">Starter (7.500 kr)</option>
        <option value="pro">Pro (14.500 kr)</option>
        <option value="usikker">Usikker / vil høre mere</option>
      </select>
    </div>
  )}
  
  <!-- Message field -->
  <div class="form-group">
    <label for="message" class="block text-sm font-semibold mb-2">
      Besked
    </label>
    <textarea
      id="message"
      name="message"
      rows="4"
      placeholder="Beskriv dit problem eller hvad du gerne vil opnå..."
      class="w-full px-4 py-3 bg-background border border-border rounded-lg focus:ring-2 focus:ring-accent focus:border-transparent transition-all resize-y"
    ></textarea>
  </div>
  
  <!-- Submit button -->
  <button
    type="submit"
    class="btn-rescue w-full text-lg py-4"
  >
    Send min hjemmeside til gratis audit
  </button>
  
  <p class="text-sm text-muted text-center">
    Jeg vender tilbage inden for 24 timer på hverdage.
  </p>
</form>

<script>
  // Client-side form validation and enhancement
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    
    if (form) {
      form.addEventListener('submit', (e) => {
        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        
        // Disable button to prevent double submission
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Sender...';
        }
        
        // Basic validation
        const websiteInput = form.querySelector('#website') as HTMLInputElement;
        if (websiteInput && websiteInput.value) {
          // Ensure URL has protocol
          if (!websiteInput.value.match(/^https?:\/\//i)) {
            websiteInput.value = 'https://' + websiteInput.value;
          }
        }
      });
    }
  });
</script>
