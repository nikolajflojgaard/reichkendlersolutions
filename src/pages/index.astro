---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout description="ReichkendlerSolutions opgraderer hjemmesider og bygger nye løsninger for danske virksomheder. Fast pris. Hurtig levering. Klare resultater.">
  <Header />
  
  <main id="main-content">
    <!-- Hero Section -->
    <section class="hero-section relative min-h-[80vh] flex items-center justify-center px-4 py-20 overflow-hidden">
      <!-- Background glow -->
      <div class="absolute inset-0 overflow-hidden">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent/10 rounded-full blur-3xl"></div>
        <div class="absolute bottom-1/4 right-1/4 w-96 h-96 bg-accent-secondary/10 rounded-full blur-3xl"></div>
      </div>
      
      <div class="relative z-10 max-w-4xl mx-auto text-center">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 bg-accent/20 border border-accent/30 rounded-full px-4 py-2 mb-8 animate-pulse-glow">
          <span class="w-2 h-2 bg-accent rounded-full animate-pulse"></span>
          <span class="text-sm font-semibold text-accent">ReichkendlerSolutions • Hjemmesideopgradering + ny hjemmeside • 5-20 dage • Fast pris</span>
        </div>
        
        <!-- Main headline -->
        <h1 class="text-5xl sm:text-6xl md:text-7xl font-extrabold mb-6 leading-tight">
          Din hjemmeside 
          <span class="gradient-text">dræner</span>
          <br />
          penge hver dag
        </h1>
        
        <!-- Subheadline -->
        <p class="text-xl sm:text-2xl text-muted max-w-2xl mx-auto mb-10">
          Vi <span class="text-accent font-semibold">opgraderer eksisterende hjemmesider</span> og 
          <span class="text-accent font-semibold">bygger nye fra bunden</span>.
          Alt med fokus på én ting: <span class="text-foreground font-semibold">fler kunder</span>.
        </p>
        
        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center items-center mb-16">
          <a href="/priser" class="btn-primary text-lg">
            Se priser
          </a>
          <a href="/om" class="btn-outline text-lg">
            Læs om mig
          </a>
        </div>
        
        <!-- Trust badges -->
        <div class="flex flex-wrap justify-center gap-6 text-sm text-muted">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Ingen skjulte gebyrer</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Fast pris</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-success" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
            </svg>
            <span>Målbare resultater</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem Section -->
    <section class="py-20 px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <p class="text-accent font-semibold uppercase tracking-wider mb-4">Problemet</p>
          <h2 class="text-4xl font-bold mb-6">
            Din hjemmeside ser måske <span class="gradient-text">"fin"</span> ud...
          </h2>
          <p class="text-xl text-muted max-w-2xl mx-auto">
            ...men hvis den ikke skaber kunder, er den en udgift — ikke en investering.
          </p>
        </div>
        
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
          <div class="brand-card p-6 text-center">
            <div class="w-14 h-14 bg-red-500/20 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <h3 class="font-bold mb-2">Ingen henvendelser</h3>
            <p class="text-sm text-muted">Besøgende kommer, men kontakter dig ikke</p>
          </div>
          
          <div class="brand-card p-6 text-center">
            <div class="w-14 h-14 bg-orange-500/20 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" />
              </svg>
            </div>
            <h3 class="font-bold mb-2">Høj bounce rate</h3>
            <p class="text-sm text-muted">Folk forlader sitet efter få sekunder</p>
          </div>
          
          <div class="brand-card p-6 text-center">
            <div class="w-14 h-14 bg-yellow-500/20 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-yellow-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z" />
              </svg>
            </div>
            <h3 class="font-bold mb-2">Dårlig mobil</h3>
            <p class="text-sm text-muted">70% af trafikken er mobil — dit site klarer den ikke</p>
          </div>
          
          <div class="brand-card p-6 text-center">
            <div class="w-14 h-14 bg-gray-500/20 rounded-xl flex items-center justify-center mx-auto mb-4">
              <svg class="w-7 h-7 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <h3 class="font-bold mb-2">Uklart budskab</h3>
            <p class="text-sm text-muted">Besøgende forstår ikke hvad du tilbyder</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Solution Section -->
    <section class="py-20 px-4 bg-muted/30">
      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-accent font-semibold uppercase tracking-wider mb-4">Løsningen</p>
            <h2 class="text-4xl font-bold mb-6">
              Vi gør din hjemmeside til en <span class="gradient-text">konverteringsmaskine</span>
            </h2>
            
            <p class="text-lg text-muted mb-8">
              ReichkendlerSolutions handler om én ting: 
              <strong class="text-foreground">at få flere kunder ud af dit website.</strong>
              Uanset om vi opgraderer din nuværende side eller bygger en ny fra bunden.
            </p>
            
            <ul class="space-y-4">
              <li class="flex items-center gap-3">
                <div class="w-8 h-8 bg-accent/20 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span>5-10 arbejdsdage</span>
              </li>
              <li class="flex items-center gap-3">
                <div class="w-8 h-8 bg-accent/20 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span>Fast pris — ingen overraskelser</span>
              </li>
              <li class="flex items-center gap-3">
                <div class="w-8 h-8 bg-accent/20 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span>Målbare KPI'er før/efter</span>
              </li>
              <li class="flex items-center gap-3">
                <div class="w-8 h-8 bg-accent/20 rounded-full flex items-center justify-center flex-shrink-0">
                  <svg class="w-4 h-4 text-accent" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </div>
                <span>AI-accelereret arbejde = hurtigere levering</span>
              </li>
            </ul>
          </div>
          
          <div class="relative">
            <div class="brand-card p-8">
              <div class="flex items-center justify-between mb-6">
                <span class="text-sm text-muted">Før opgradering</span>
                <span class="text-sm text-success font-bold">Efter opgradering</span>
              </div>
              
              <div class="space-y-6">
                <div>
                  <div class="flex justify-between text-sm mb-2">
                    <span>Kontakt-rate</span>
                    <span class="font-bold">2% → 8%</span>
                  </div>
                  <div class="h-3 bg-muted rounded-full overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full" style="width: 80%"></div>
                  </div>
                </div>
                
                <div>
                  <div class="flex justify-between text-sm mb-2">
                    <span>Mobil bounce rate</span>
                    <span class="font-bold">65% → 35%</span>
                  </div>
                  <div class="h-3 bg-muted rounded-full overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full" style="width: 65%"></div>
                  </div>
                </div>
                
                <div>
                  <div class="flex justify-between text-sm mb-2">
                    <span>Tid på side</span>
                    <span class="font-bold">45s → 2m 30s</span>
                  </div>
                  <div class="h-3 bg-muted rounded-full overflow-hidden">
                    <div class="h-full bg-gradient-to-r from-accent to-accent-secondary rounded-full" style="width: 85%"></div>
                  </div>
                </div>
              </div>
              
              <div class="mt-6 pt-6 border-t border-border">
                <p class="text-sm text-muted"><strong class="text-foreground">Typisk resultat</strong> efter en opgradering. Dine resultater kan variere.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Process Section -->
    <section class="py-20 px-4">
      <div class="max-w-5xl mx-auto">
        <div class="text-center mb-16">
          <p class="text-accent font-semibold uppercase tracking-wider mb-4">Processen</p>
          <h2 class="text-4xl font-bold mb-6">Sådan virker det</h2>
          <p class="text-xl text-muted max-w-2xl mx-auto">
            Fra første kontakt til launch på kun 5 dage.
          </p>
        </div>
        
        <div class="grid md:grid-cols-4 gap-6">
          <div class="brand-card p-6 relative">
            <div class="absolute -top-3 -left-3 w-10 h-10 bg-accent rounded-full flex items-center justify-center text-white font-bold text-lg">1</div>
            <h3 class="font-bold mb-2 mt-2">Gratis audit</h3>
            <p class="text-sm text-muted">Jeg analyserer dit site og finder de største quick wins.</p>
          </div>
          
          <div class="brand-card p-6 relative">
            <div class="absolute -top-3 -left-3 w-10 h-10 bg-accent rounded-full flex items-center justify-center text-white font-bold text-lg">2</div>
            <h3 class="font-bold mb-2 mt-2">Scope & aftale</h3>
            <p class="text-sm text-muted">Vi fastlægger præcis hvad der skal gøres og prisen.</p>
          </div>
          
          <div class="brand-card p-6 relative">
            <div class="absolute -top-3 -left-3 w-10 h-10 bg-accent rounded-full flex items-center justify-center text-white font-bold text-lg">3</div>
            <h3 class="font-bold mb-2 mt-2">Design & build</h3>
            <p class="text-sm text-muted">Jeg designer, du godkender, jeg bygger. 3-4 dage.</p>
          </div>
          
          <div class="brand-card p-6 relative">
            <div class="absolute -top-3 -left-3 w-10 h-10 bg-accent rounded-full flex items-center justify-center text-white font-bold text-lg">4</div>
            <h3 class="font-bold mb-2 mt-2">Launch & mål</h3>
            <p class="text-sm text-muted">Dit nye site går live med KPI-baseline.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <div class="brand-card p-12 relative overflow-hidden">
          <div class="absolute top-0 right-0 w-64 h-64 bg-accent/10 rounded-full blur-3xl"></div>
          <div class="absolute bottom-0 left-0 w-64 h-64 bg-accent-secondary/10 rounded-full blur-3xl"></div>
          
          <div class="relative z-10">
            <h2 class="text-4xl font-bold mb-6">
              Klar til <span class="gradient-text">flere kunder</span>?
            </h2>
            
            <p class="text-xl text-muted mb-8 max-w-2xl mx-auto">
              Få en gratis audit af dit nuværende site, eller lad os bygge noget nyt sammen.
            </p>
            
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/kontakt" class="btn-primary text-lg">
                Gratis audit
              </a>
              <a href="/priser" class="btn-outline text-lg">
                Se alle priser
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>
