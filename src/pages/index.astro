---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import { SITE } from "@/config";
import Layout from "@/layouts/Layout.astro";
---

<Layout description="Conversion-focused website upgrade for small businesses. 5-day turnaround.">
  <Header />
  <main id="main-content" class="mx-auto w-full max-w-3xl px-4 pb-12">
    <section class="pt-12 pb-6">
      <div class="flex flex-col sm:flex-row items-start gap-6 mb-8">
        <img src="/avatar.jpg" alt="Nikolaj Fløjgaard" class="w-24 h-24 rounded-full object-cover" />
        <div>
          <h1 class="text-2xl font-bold tracking-wide sm:text-3xl mb-2">
            Website Rescue
          </h1>
          <p class="text-muted">Af Nikolaj Fløjgaard</p>
        </div>
      </div>
      
      <p class="text-lg mb-4">
        Din hjemmeside skal ikke bare se pæn ud. Den skal skabe henvendelser.
      </p>
      <p class="text-muted mb-8">
        Jeg hjælper små virksomheder med at få mere ud af deres website — med fokus på 
        <strong>konvertering</strong>, ikke bare design. <strong>5 arbejdsdage.</strong> Fast pris.
      </p>
    </section>

    <section class="prose mb-12">
      <h2 class="text-xl font-semibold mb-4">Hvem er jeg?</h2>
      <p>
        Jeg er Senior Integration Architect hos TDC NET, hvor jeg bygger automation og workflows 
        der skalerer. I min fritid udvikler jeg Home Assistant integrationer og eksperimenterer 
        med de nyeste AI-modeller.
      </p>
      <p>
        Website Rescue er mit bud på at hjælpe mindre virksomheder — dem der ikke har råd til 
        et dyrt bureau, men stadig fortjener en hjemmeside der <strong>faktisk skaber kunder</strong>.
      </p>
      <p>
        Jeg arbejder hurtigt fordi jeg bruger AI som force multiplier — det betyder lavere 
        priser for dig og hurtigere levering.
      </p>
    </section>

    <section class="prose mb-12">
      <h2 class="text-xl font-semibold mb-4">Hvad jeg løser</h2>
      <ul>
        <li>Hjemmesider der ser "ok" ud, men konverterer ikke</li>
        <li>Uklar value proposition</li>
        <li>Svage eller ingen CTA'er</li>
        <li>Dårlig mobiloplevelse</li>
        <li>Manglende tillidssignaler</li>
      </ul>
    </section>

    <section class="prose mb-12">
      <h2 class="text-xl font-semibold mb-4">Pakker</h2>
      
      <div class="grid gap-6 not-prose">
        <div class="border border-border rounded-lg p-6">
          <h3 class="text-lg font-semibold mb-2">Starter — 7.500 DKK + moms</h3>
          <p class="text-sm text-muted mb-4">5 arbejdsdage</p>
          <ul class="text-sm space-y-1">
            <li>Forside + 2 undersider redesignet</li>
            <li>CTA-struktur (Ring / Book / Kontakt)</li>
            <li>Mobiloptimering</li>
            <li>Basic SEO (title/meta/OG)</li>
            <li>Hastigheds quick wins</li>
            <li>Tracking (GA4 + conversion events)</li>
            <li>Før/efter KPI baseline</li>
          </ul>
        </div>

        <div class="border border-accent rounded-lg p-6 bg-accent/5">
          <h3 class="text-lg font-semibold mb-2">Pro — 14.500 DKK + moms</h3>
          <p class="text-sm text-muted mb-4">10 arbejdsdage</p>
          <p class="text-sm mb-2">Alt i Starter +</p>
          <ul class="text-sm space-y-1">
            <li>Tekst/positionering rewrite</li>
            <li>Content plan (6 emner)</li>
            <li>Leadflow (form + auto-opfølgning)</li>
            <li>30 dages growth support</li>
            <li>Prioriteret supportkanal</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="prose mb-12">
      <h2 class="text-xl font-semibold mb-4">Sådan arbejder jeg (hurtigt)</h2>
      <ol>
        <li><strong>Gratis mini-audit</strong> — jeg analyserer dit nuværende site (5 punkter)</li>
        <li><strong>Scope & prioritering</strong> — vi aftaler specifikt hvad der fix først</li>
        <li><strong>Implementering</strong> — jeg bygger, du godkender</li>
        <li><strong>Launch & måling</strong> — live med KPI-baseline</li>
      </ol>
    </section>

    <section class="prose mb-12">
      <h2 class="text-xl font-semibold mb-4">KPI'er jeg måler på</h2>
      <ul>
        <li><strong>Kontakt-rate</strong> — hvor mange % af besøgende tager kontakt</li>
        <li><strong>Mobil bounce rate</strong> — forlader de med det samme?</li>
        <li><strong>Tid på side</strong> — engagerer indholdet?</li>
      </ul>
    </section>

    <section class="prose mb-12 bg-accent/5 border border-accent rounded-lg p-6">
      <h2 class="text-xl font-semibold mb-4">Gratis mini-audit (5 punkter)</h2>
      <p class="mb-4">
        Skriv <strong>"audit"</strong> på 
        <a href="https://dk.linkedin.com/in/nikolaj-fl%C3%B8jgaard-90a71b109" target="_blank">LinkedIn</a> 
        eller <a href="https://x.com/FlJgaard" target="_blank">X</a>, 
        så sender jeg dig:
      </p>
      <ul>
        <li>Top 3 conversion-fixes for dit site</li>
        <li>Estimeret effort</li>
        <li>Anbefalet pakke (Starter/Pro)</li>
        <li>Fast pris — ingen overraskelser</li>
      </ul>
    </section>
  </main>
  <Footer />
</Layout>
