---
import Footer from "@/components/Footer.astro";
import Header from "@/components/Header.astro";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Tak for din henvendelse | Website Rescue" description="Din henvendelse er modtaget. Jeg vender tilbage inden for 24 timer.">
  <Header />
  
  <main id="main-content" class="mx-auto w-full max-w-2xl px-4 pb-12 min-h-[60vh] flex items-center">    
    <section class="w-full text-center py-20">      
      <div class="w-20 h-20 bg-success/20 rounded-full flex items-center justify-center mx-auto mb-8">
        <svg class="w-10 h-10 text-success" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
        </svg>
      </div>
      
      <h1 class="text-4xl font-extrabold mb-4">
        Tak for din <span class="gradient-text">henvendelse</span>!
      </h1>      
      
      <p class="text-xl text-muted mb-8">
        Jeg har modtaget din hjemmeside og kigger den igennem så hurtigt som muligt.
      </p>
      
      <div class="rescue-card p-8 mb-8 text-left">
        <h3 class="font-bold mb-4">Hvad sker der nu?</h3>        
        <ol class="space-y-3 text-muted">
          <li>Du får en email-bekræftelse inden for få minutter</li>
          <li>Jeg analyserer din hjemmeside (tager ca. 30 min)</li>
          <li>Du modtager din mini-audit inden for 24 timer på hverdage</li>
        </ol>
      </div>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">        <a href="/" class="btn-outline">
          Tilbage til forsiden
        </a>        
        <a href="/priser" class="btn-rescue">
          Se priser
        </a>
      </div>      
    </section>
  </main>
  
  <Footer />
</Layout>
